{{#> layout}}
  {{#*inline "title"}}{{album.title}}{{/inline}}
  {{#*inline "content"}}
    <section>
      <div class="content">
        <h1 class="title"><a href="/">{{configuration.title}}</a> &raquo; {{album.title}}</h1>
        <div class="description">
          {{&markdown album.description}}
        </div>
        <small>Created {{album.created}}</small>
        <h2 class="subtitle">Highlights</h2>
      </div>
      <div class="columns is-multiline is-tablet">
        <div class="column is-one-third">
          <figure class="image is-4by3">
            <img src="https://via.placeholder.com/640x480">
          </figure>
        </div>
        <div class="column is-one-third">
          <figure class="image is-4by3">
            <img src="https://via.placeholder.com/640x480">
          </figure>
        </div>
        <div class="column is-one-third">
          <figure class="image is-4by3">
            <img src="https://via.placeholder.com/640x480">
          </figure>
        </div>
        <div class="column is-one-third">
          <figure class="image is-4by3">
            <img src="https://via.placeholder.com/640x480">
          </figure>
        </div>
      </div>
    </section>
  {{/inline}}
{{/layout}}