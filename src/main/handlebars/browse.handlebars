{{#> layout}}
  {{#*inline "title"}}Home{{/inline}}
  {{#*inline "content"}}
    <h1>{{title}}</h1>

    {{#each albums}}
      <section>
        <h2><a href="/album/{{name}}">{{title}}</a></h2>
        <small>Created {{created}}</small>

        <ul class="highlights">
          <li><img src="https://via.placeholder.com/200"></li>
          <li><img src="https://via.placeholder.com/200"></li>
          <li><img src="https://via.placeholder.com/200"></li>
        </ul>

        <a href="/album/{{name}}">More</a>
      </section>
    {{/each}}
  {{/inline}}
{{/layout}}